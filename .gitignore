# ===========================================================================
# .gitignore — hongc-okx 永续合约 AI 交易系统
# 更新: 2025-06-21
# ===========================================================================

# ── 密钥与凭证 ────────────────────────────────────────
.env
.env.*
!.env.example
!.env.template
*.pem
*.key

# ── Python 项目 ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/

# ── Python 虚拟环境 ────────────────────────────────────
.venv/
venv/
env/

# ── Node / 前端 ────────────────────────────────────────
node_modules/
dist/
*.tsbuildinfo

# ── 运行时数据 ────────────────────────────────────────
data/**/*
!data/**/.gitkeep
*.log

# ── 测试产物 ──────────────────────────────────────────
backend/tests/reports/*
!backend/tests/reports/.gitkeep
.coverage
.coverage.*

# ── 数据库 ────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Streamlit 遗留配置 ──────────────────────────────────
.streamlit/
.streamlit_config/

# ── IDE / 编辑器 ──────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Claude Code ────────────────────────────────────────
.claude/

# ── 系统文件 ──────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── 前端测试产物 ──────────────────────────────────────
test-results/
playwright-report/

# ── 临时文件 ──────────────────────────────────────────
temp/
*.tmp
