# ========================================
# OKX 永续合约 AI 自动交易系统配置文件
# ========================================

# ========== 交易配置 ==========
TRADE_SYMBOL=DOGE/USDT:USDT
TRADE_LEVERAGE=10
TRADE_TIMEFRAME=3m
TRADE_DATA_POINTS=200
TRADE_TICK_INTERVAL_SECONDS=120
TRADE_ORDER_AMOUNT=10.0
TRADE_MAX_POSITION_RATIO=0.8
AGENT_AUTO_START=true
AGENT_MODE=1_agent

# ========== 风控参数 ==========
MAX_DAILY_DRAWDOWN_PCT=10.0
MAX_DAILY_LOSS_USDT=10.0
OKX_SANDBOX=true

# ========== AI模型配置 ==========
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DASHSCOPE_API_KEY=sk-your-qwen-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CRYPTORACLE_API_KEY=your-cryptoracle-api-key

# ========== OKX 主账户 (实盘) ==========
OKX_MAIN_API_KEY=your-main-api-key
OKX_MAIN_SECRET=your-main-secret
OKX_MAIN_PASSWORD=your-main-password

# ========== OKX 模拟账户 (模拟盘) ==========
OKX_DEMO_API_KEY=your-demo-api-key
OKX_DEMO_SECRET=your-demo-secret
OKX_DEMO_PASSWORD=your-demo-password

# ========== 网络代理配置 ==========
HTTPS_PROXY=http://127.0.0.1:7890
HTTPS_PROXY_BACKUP=http://127.0.0.1:7890

# ========== PostgreSQL (持久存储) ==========
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=trading

# ========== Redis (缓存 + Pub/Sub) ==========
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
