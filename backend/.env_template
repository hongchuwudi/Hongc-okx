# ========================================
# OKX 永续合约 AI 自动交易系统配置文件
# ========================================

# ========== 交易配置 ==========
# 交易对（OKX 格式: BTC/USDT:USDT, DOGE/USDT:USDT, ETH/USDT:USDT）
TRADE_SYMBOL=DOGE/USDT:USDT
# 杠杆倍数（10 = 10x）
TRADE_LEVERAGE=10
# 是否自动启动 Agent 交易引擎（true=启动，false=仅 API 服务）
AGENT_AUTO_START=true
# Agent 模式: 5_agent（完整模式）| 3_agent（快速模式）
AGENT_MODE=5_agent

# ========================================
# 运行时配置说明
# ========================================
# 以下配置可在 .env 中设默认值，运行时通过 Redis 实时修改（无需重启）。
# 前端 PUT /api/v1/config/runtime 直接写入 Redis，引擎下个 tick 立即生效。
# 优先级: Redis > .env > 硬编码默认值
#
# 可动态修改的字段:
#   agent_mode              — Agent 模式 (5_agent / 3_agent，重启后生效)
#   tick_interval_seconds   — Tick 间隔秒数 (默认 360 = 6min)
#   order_amount            — 每次开仓 USDT 金额 (默认 1.0)
#   max_position_ratio      — 最大仓位比例 (默认 0.8)
#   max_daily_drawdown_pct  — 最大日回撤百分比 (默认 10.0)
#   max_daily_loss_usdt     — 最大日亏损 USDT (默认 50.0)
#   leverage                — 杠杆倍数 (默认 10，重启后生效)
#   symbol                  — 交易对 (默认 DOGE/USDT:USDT，重启后生效)
# ========================================

# ========== AI模型配置 ==========
# 可选值: deepseek 或 qwen
AI_PROVIDER=deepseek

# DeepSeek API密钥 (如果使用DeepSeek)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里百炼API密钥 (如果使用Qwen)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# 市场情绪数据 (cryptoracle.network，可选)
CRYPTORACLE_API_KEY=

# ========== OKX 主账户 (实盘) ==========
# 仅在 OKX_SANDBOX=false 时使用
OKX_MAIN_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OKX_MAIN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OKX_MAIN_PASSWORD=xxxxxxxx

# ========== OKX 模拟账户 (模拟盘) ==========
# 仅在 OKX_SANDBOX=true 时使用
OKX_DEMO_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OKX_DEMO_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OKX_DEMO_PASSWORD=xxxxxxxx

# ========== 网络代理配置（国内服务器必填）==========
# 如果无法连接 okx.com，填写代理地址，例如:
# HTTPS_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=
# 备用代理（主代理不通时自动切换）
# HTTPS_PROXY_BACKUP=http://127.0.0.1:7891

# ========== PostgreSQL (持久存储) ==========
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=root
POSTGRES_PASSWORD=
POSTGRES_DB=trading

# ========== Redis (缓存 + Pub/Sub) ==========
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== 风控参数 ==========
MAX_DAILY_DRAWDOWN_PCT=10.0
MAX_DAILY_LOSS_USDT=50.0
OKX_SANDBOX=true
